# ----------------------------------------------------------------------------
# Polymarket copytrading paper-trade bot — configuration
# Copy this file to ".env" and fill in the values:   cp .env.example .env
# ----------------------------------------------------------------------------

# The Polymarket user (proxy wallet) to copy. Default = @RN1.
TARGET_ADDRESS=0x2005d16a84ceefa912d4e380cd32e7ff827875ea

# Fraction of RN1's size to copy. 0.01 = 1% of their share size per trade.
SCALE_RATIO=0.01

# Ignore trades worth less than this many dollars (Polymarket's order minimum is $1).
MIN_TRADE_USD=1.0

# How often (seconds) to poll for new trades and re-price positions.
POLL_INTERVAL_SECONDS=30

# How many of RN1's trades to fetch per poll (most recent first).
TRADES_PER_POLL=200

# ---- Local Excel datastore -------------------------------------------------
# Path to the .xlsx file the bot writes to. Created automatically if missing.
# Leave blank to use ./polymarket_paper_trades.xlsx next to the scripts.
EXCEL_PATH=/Users/aidanosullivan/Desktop/polymarket_paper_trades.xlsx
